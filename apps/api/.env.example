PORT=3001

# LLM API (9router or any OpenAI-compatible endpoint)
LLM_BASE_URL=http://127.0.0.1:20128/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=kr/claude-sonnet-4.6

# Tool execution
EXECUTION_TIMEOUT=60000

# OpenClaw Gateway (optional — falls back to LLM if not set)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# LLM models per tool (via 9router)
TOOL_MODEL_OPENCLAW=kr/claude-sonnet-4.6
TOOL_MODEL_HERMES=ds/deepseek-v4-flash
TOOL_MODEL_KIRO=kr/claude-sonnet-4.6
TOOL_MODEL_ANTIGRAVITY=kr/claude-opus-4.6
TOOL_MODEL_CODEX=cx/gpt-5.5
TOOL_MODEL_CLAUDE_CODE=kr/claude-sonnet-4.6

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=8511701523
